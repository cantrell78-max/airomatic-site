---
interface Props {
  url: string;
  title?: string;
  height?: number;
}

const { url, title = "Embedded app", height = 920 } = Astro.props;
---

<div class="space-embed">
  <iframe
    src={url}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen></iframe>
</div>

<style define:vars={{ height: `${height}px` }}>
  .space-embed {
    position: relative;
    width: 100%;
    height: var(--height);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    margin: 1.5rem 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .space-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>