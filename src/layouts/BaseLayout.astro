---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SchematicBg from "../components/SchematicBg.astro";
import { site } from "../config/site";

interface Props {
  title: string;
  description?: string;
  section?: string;
}

const {
  title,
  description = "Airomatic — an AI startup building tools in public. Watch live Grok Build coding sessions on YouTube.",
  section,
} = Astro.props;
const fullTitle =
  title === "Home"
    ? "Airomatic | AI Tools Built in Public"
    : section && title === section
      ? `${section} | Airomatic`
      : section
        ? `${title} | ${section} | Airomatic`
        : `${title} | Airomatic`;
const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = new URL("/images/brand/logo-lockup.webp", site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/images/brand/favicon-192.png" sizes="192x192" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Airomatic — airomatic.ai" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#06070b" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <SchematicBg />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>