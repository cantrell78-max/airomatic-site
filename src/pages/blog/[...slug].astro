---
import BaseLayout from "../../layouts/BaseLayout.astro";
import KatexHead from "../../components/math/KatexHead.astro";
import SpaceEmbed from "../../components/SpaceEmbed.astro";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <KatexHead slot="head" />
  <article class="section">
    <div class="container prose">
      <p class="eyebrow">Blog</p>
      <h1>{post.data.title}</h1>
      <time class="mono" datetime={post.data.pubDate.toISOString()} style="font-size: 0.85rem; color: var(--text-muted)">
        {
          post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
      {post.data.youtubeId && <YouTubeEmbed id={post.data.youtubeId} title={post.data.title} />}
      <Content />
      {
        post.data.embedUrl && (
          <>
            <h2>Try the live dashboard</h2>
            <p>
              Running on Hugging Face — click <strong>Refresh</strong> to pull the latest X posts and run Grok
              analysis.{" "}
              <a href="https://huggingface.co/spaces/airomatic/xmoney" target="_blank" rel="noopener noreferrer">
                Open in a new tab
              </a>
              .
            </p>
            <SpaceEmbed url={post.data.embedUrl} title={post.data.title} />
          </>
        )
      }
    </div>
  </article>
</BaseLayout>