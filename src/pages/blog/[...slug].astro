---
import BaseLayout from "../../layouts/BaseLayout.astro";
import KatexHead from "../../components/math/KatexHead.astro";
import SpaceEmbed from "../../components/SpaceEmbed.astro";
import YouTubeEmbed from "../../components/YouTubeEmbed.astro";
import StartupCard from "../../components/StartupCard.astro";
import { site } from "../../config/site";
import { getStartupsSorted } from "../../lib/startups";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const featuredIds = post.data.featuredStartupIds ?? [];
const featuredStartups = featuredIds
  .map((id) => getStartupsSorted().find((s) => s.id === id))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogImageAlt={`${post.data.title} — ${site.name}`}
  ogType="article"
>
  <KatexHead slot="head" />
  <article class="section">
    <div class="container prose">
      <p class="eyebrow">Blog</p>
      <h1>{post.data.title}</h1>
      <time class="mono" datetime={post.data.pubDate.toISOString()} style="font-size: 0.85rem; color: var(--text-muted)">
        {
          post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
      {post.data.youtubeId && <YouTubeEmbed id={post.data.youtubeId} title={post.data.title} />}
      <Content />
      {
        featuredStartups.length > 0 && (
          <section class="featured-startups" aria-label="Featured startup announcements">
            <h2>From the archive</h2>
            <p>
              A few announcements from{" "}
              <a href="/startups/">Agentic AI Startup News</a> — click any card to open the full living archive.
            </p>
            <div class="featured-startups__grid">
              {featuredStartups.map((startup) => (
                <StartupCard startup={startup} href="/startups/" />
              ))}
            </div>
            <p>
              <a href="/startups/">Browse all announcements →</a>
            </p>
          </section>
        )
      }
      {
        post.data.embedUrl && (
          <>
            <h2>Try the live dashboard</h2>
            <p>
              Running on Hugging Face — click <strong>Refresh</strong> to pull the latest X posts and run Grok
              analysis.{" "}
              <a href="https://huggingface.co/spaces/airomatic/xmoney" target="_blank" rel="noopener noreferrer">
                Open in a new tab
              </a>
              .
            </p>
            <SpaceEmbed url={post.data.embedUrl} title={post.data.title} />
          </>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .featured-startups {
    margin-top: 2.5rem;
    max-width: none;
  }

  .featured-startups__grid {
    display: grid;
    gap: 1.25rem;
    margin: 1.5rem 0;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .featured-startups__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .featured-startups__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Cards sit outside the narrow prose column */
  .featured-startups :global(.startup-card__name) {
    font-size: 1.1rem;
  }
</style>
