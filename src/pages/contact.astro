---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site, formspreeAction } from "../config/site";
---

<BaseLayout
  title="Contact"
  description="Contact Airomatic — questions about live sessions, collaborations, or AI tooling."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch</h1>
      <p class="lead">
        Questions about a live session, a collaboration, or what we're building? Send a message.
      </p>

      <div class="contact-grid">
        {
          formspreeAction ? (
            <form class="card contact-form" action={formspreeAction} method="POST">
              <input type="text" name="_gotcha" class="contact-form__honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
              <input type="hidden" name="_subject" value="Airomatic — new inquiry" />
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="5" required placeholder="What can we help with?"></textarea>
              </div>
              <button type="submit" class="btn">Send message</button>
            </form>
          ) : (
            <div class="card contact-form contact-form--pending">
              <h3 style="margin-top: 0">Email us directly</h3>
              <p style="margin: 0; color: var(--text-muted)">
                The contact form will go live once Formspree is connected. For now, reach out by email:
              </p>
              {
                site.contactEmail ? (
                  <p style="margin: 1rem 0 0">
                    <a href={`mailto:${site.contactEmail}`} class="btn">{site.contactEmail}</a>
                  </p>
                ) : (
                  <p class="mono" style="font-size: 0.8rem; margin: 1rem 0 0; color: var(--text-muted)">
                    Add <code>PUBLIC_CONTACT_EMAIL</code> or <code>PUBLIC_FORMSPREE_ID</code> in a <code>.env</code> file (see <code>env.example</code>).
                  </p>
                )
              }
            </div>
          )
        }

        <div>
          <div class="card" style="margin-bottom: 1.25rem">
            <h3 style="margin-top: 0">Elsewhere</h3>
            <p style="margin: 0; color: var(--text-muted)">
              Follow the build and catch live sessions on YouTube.
            </p>
            {
              site.youtubeUrl ? (
                <p style="margin: 1rem 0 0">
                  <a href={site.youtubeUrl} target="_blank" rel="noopener noreferrer">
                    YouTube channel →
                  </a>
                </p>
              ) : (
                <p class="mono" style="font-size: 0.8rem; margin: 1rem 0 0; color: var(--text-muted)">
                  Set <code>PUBLIC_YOUTUBE_URL</code> in <code>.env</code> when your channel is ready.
                </p>
              )
            }
            <p style="margin: 1rem 0 0">
              <a href="https://aeromaticdrone.com" target="_blank" rel="noopener noreferrer">
                Aeromatic Drone Services →
              </a>
            </p>
          </div>

          <div class="card">
            <h3 style="margin-top: 0">Live sessions</h3>
            <p style="margin: 0; color: var(--text-muted); font-size: 0.95rem">
              Want to suggest a topic for a future Grok Build stream? Mention it in your message.
            </p>
            <p style="margin: 1.25rem 0 0">
              <a href="/live/" class="btn btn--ghost">Live page</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-form button {
    cursor: pointer;
    border: none;
    font: inherit;
  }

  .contact-form--pending {
    border-color: var(--border);
  }

  .contact-form__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
</style>