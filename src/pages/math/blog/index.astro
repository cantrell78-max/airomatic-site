---
import MathLayout from '../../../layouts/MathLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('mathBlog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<MathLayout title="Blog" description="Sample blog posts demonstrating KaTeX math in Markdown.">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Math blog</p>
      <h1>Posts with math</h1>
      <p class="lead">
        Articles written in Markdown with inline and display LaTeX, rendered at build time via
        <code>remark-math</code> and <code>rehype-katex</code>.
      </p>

      {
        posts.length > 0 ? (
          <ul class="blog-list" style="margin-top: 2rem;">
            {posts.map((post) => (
              <li>
                <a href={`/math/blog/${post.id}/`}>{post.data.title}</a>
                <span style="display: block; color: var(--text-muted); font-size: 0.95rem; margin-top: 0.25rem;">
                  {post.data.description}
                </span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </li>
            ))}
          </ul>
        ) : (
          <p class="card" style="margin-top: 2rem; color: var(--text-muted);">No posts yet.</p>
        )
      }
    </div>
  </section>
</MathLayout>