---
import MathLayout from '../../layouts/MathLayout.astro';
import MathComparison from '../../components/math/MathComparison.astro';

const examples = [
  {
    title: 'Inline math in a sentence',
    source: 'The golden ratio $\\varphi$ satisfies $\\varphi^2 = \\varphi + 1$.',
    tex: '\\varphi',
    display: false,
  },
  {
    title: 'Display equation (block)',
    source: '$$e^{i\\pi} + 1 = 0$$',
    tex: 'e^{i\\pi} + 1 = 0',
    display: true,
  },
  {
    title: 'Fractions and roots',
    source: '$$x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}$$',
    tex: 'x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}',
    display: true,
  },
  {
    title: 'Summation and integrals',
    source: '$$\\sum_{n=1}^{\\infty} \\frac{1}{n^2} = \\frac{\\pi^2}{6}, \\quad \\int_0^1 x^2\\,dx = \\frac{1}{3}$$',
    tex: '\\sum_{n=1}^{\\infty} \\frac{1}{n^2} = \\frac{\\pi^2}{6}, \\quad \\int_0^1 x^2\\,dx = \\frac{1}{3}',
    display: true,
  },
  {
    title: 'Mandelbrot iteration',
    source: '$$z_{n+1} = z_n^2 + c, \\quad z_0 = 0$$',
    tex: 'z_{n+1} = z_n^2 + c, \\quad z_0 = 0',
    display: true,
  },
  {
    title: 'Polar curve (rose)',
    source: '$$r = a\\cos(k\\theta) \\quad \\text{(rose curve)}$$',
    tex: 'r = a\\cos(k\\theta) \\quad \\text{(rose curve)}',
    display: true,
  },
  {
    title: 'Using the Math component in .astro',
    source: `<Math tex="\\int_{-\\infty}^{\\infty} e^{-x^2}\\,dx = \\sqrt{\\pi}" display />`,
    tex: '\\int_{-\\infty}^{\\infty} e^{-x^2}\\,dx = \\sqrt{\\pi}',
    display: true,
  },
];
---

<MathLayout
  title="Comparison"
  description="Side-by-side comparison of Markdown LaTeX syntax and KaTeX rendered output."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Source vs. output</p>
      <h1>Markdown + KaTeX comparison</h1>
      <p class="lead">
        In <code>.md</code> blog posts, wrap math with <code>$...$</code> (inline) or <code>$$...$$</code> (display).
        In <code>.astro</code> files, use the <code>&lt;Math /&gt;</code> component for the same LaTeX strings.
      </p>

      <div class="card" style="margin-top: 2rem;">
        <h3>Syntax reference</h3>
        <table style="width: 100%; border-collapse: collapse; font-size: 0.95rem;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border); text-align: left;">
              <th style="padding: 0.75rem 0;">Context</th>
              <th style="padding: 0.75rem 0;">Inline</th>
              <th style="padding: 0.75rem 0;">Display (block)</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 0.75rem 0;">Markdown</td>
              <td style="padding: 0.75rem 0;"><code>$E = mc^2$</code></td>
              <td style="padding: 0.75rem 0;"><code>$$\int_0^1 x\,dx$$</code></td>
            </tr>
            <tr>
              <td style="padding: 0.75rem 0;">Astro component</td>
              <td style="padding: 0.75rem 0;"><code>&lt;Math tex="E = mc^2" /&gt;</code></td>
              <td style="padding: 0.75rem 0;"><code>&lt;Math tex="..." display /&gt;</code></td>
            </tr>
          </tbody>
        </table>
      </div>

      {
        examples.map((ex) => (
          <div style="margin-top: 2.5rem;">
            <h2>{ex.title}</h2>
            <MathComparison source={ex.source} tex={ex.tex} display={ex.display} />
          </div>
        ))
      }
    </div>
  </section>
</MathLayout>