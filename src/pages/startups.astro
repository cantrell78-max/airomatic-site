---
/**
 * /startups — Agentic AI Startup News
 *
 * How to add a new batch:
 * 1. Add new objects to `src/data/startups.json`
 * 2. Drop new portrait images into `public/images/startups/` with matching filenames
 * 3. The page updates automatically on rebuild
 *
 * Source of truth for the initial batch: projects/agentic-ai-startup-news/
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import StartupCard from "../components/StartupCard.astro";
import { getStartupsSorted, STARTUP_FILTERS } from "../lib/startups";

const allStartups = getStartupsSorted();
const pageSize = 6;
---

<BaseLayout
  title="Agentic AI Startup News"
  description="A living archive of satirical AI startup funding announcements — patterns detected, deals riffed, portraits generated."
>
  <section class="section startups-page">
    <div class="container">
      <p class="eyebrow">Archive</p>
      <h1>Agentic AI Startup News</h1>
      <p class="lead startups-page__intro">
        A living archive of AI startup funding announcements generated by agents
        watching the real funding feed too closely. Patterns detected. Deals
        riffed. Portraits generated.
      </p>
      <p class="startups-page__count mono">
        <span data-visible-count>{Math.min(pageSize, allStartups.length)}</span>
        of <span data-total-count>{allStartups.length}</span> announcements
      </p>

      <div
        class="startups-filters"
        role="toolbar"
        aria-label="Filter by vertical"
        data-startups-filters
      >
        {
          STARTUP_FILTERS.map((filter, i) => (
            <button
              type="button"
              class:list={[
                "startups-filters__btn",
                { "startups-filters__btn--active": i === 0 },
              ]}
              data-filter={filter}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {filter}
            </button>
          ))
        }
      </div>

      <div class="startups-grid" data-startups-grid>
        {allStartups.map((startup) => <StartupCard startup={startup} />)}
      </div>

      <p class="startups-empty" data-startups-empty hidden>
        No announcements match this filter.
      </p>

      <div class="startups-more" data-startups-more>
        <button type="button" class="btn btn--ghost" data-load-more>
          Load more
        </button>
      </div>
    </div>
  </section>

  {/* Shared modal — populated by client script */}
  <dialog class="startup-modal" data-startup-modal aria-labelledby="startup-modal-title">
    <div class="startup-modal__panel">
      <button
        type="button"
        class="startup-modal__close"
        data-startup-close
        aria-label="Close"
      >
        ×
      </button>
      <div class="startup-modal__layout">
        <div class="startup-modal__media">
          <img
            src=""
            alt=""
            width="400"
            height="400"
            data-modal-image
            class="startup-modal__portrait"
          />
        </div>
        <div class="startup-modal__content">
          <p class="startup-modal__meta mono">
            <span data-modal-round></span>
            <span aria-hidden="true"> · </span>
            <time data-modal-date></time>
          </p>
          <h2 id="startup-modal-title" data-modal-company></h2>
          <p class="startup-modal__headline" data-modal-headline></p>
          <ul class="startup-modal__tags" data-modal-tags></ul>
          <p class="startup-modal__desc" data-modal-description></p>
          <p class="startup-modal__founder mono" data-modal-founder></p>
          <blockquote class="startup-modal__quote">
            <p data-modal-founder-quote></p>
            <footer>— Founder</footer>
          </blockquote>
          <blockquote class="startup-modal__quote startup-modal__quote--investor">
            <p data-modal-investor-quote></p>
            <footer>— Investor</footer>
          </blockquote>
        </div>
      </div>
    </div>
  </dialog>
</BaseLayout>

<style>
  .startups-page__intro {
    margin-bottom: 0.75rem;
  }

  .startups-page__count {
    margin: 0 0 1.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .startups-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .startups-filters__btn {
    margin: 0;
    padding: 0.4rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--border);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .startups-filters__btn:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .startups-filters__btn--active,
  .startups-filters__btn[aria-pressed="true"] {
    color: var(--bg);
    background: var(--accent);
    border-color: var(--accent);
  }

  .startups-filters__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .startups-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .startups-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .startups-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .startups-grid :global(.startup-card[hidden]) {
    display: none;
  }

  .startups-empty {
    margin: 2rem 0;
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    border: 1px dashed var(--border);
  }

  .startups-more {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .startups-more[hidden] {
    display: none;
  }

  /* —— Modal —— */
  .startup-modal {
    width: min(100% - 2rem, 52rem);
    max-height: min(90vh, 44rem);
    margin: auto;
    padding: 0;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    overflow: hidden;
  }

  .startup-modal::backdrop {
    background: rgba(6, 7, 11, 0.78);
    backdrop-filter: blur(4px);
  }

  .startup-modal__panel {
    position: relative;
    max-height: min(90vh, 44rem);
    overflow-y: auto;
  }

  .startup-modal__close {
    position: absolute;
    top: 0.65rem;
    right: 0.75rem;
    z-index: 2;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--text-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .startup-modal__close:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .startup-modal__layout {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .startup-modal__layout {
      grid-template-columns: minmax(12rem, 16rem) 1fr;
    }
  }

  .startup-modal__media {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 720px) {
    .startup-modal__media {
      border-bottom: none;
      border-right: 1px solid var(--border);
    }
  }

  .startup-modal__portrait {
    width: 100%;
    height: 100%;
    max-height: 16rem;
    object-fit: cover;
    object-position: center top;
  }

  @media (min-width: 720px) {
    .startup-modal__portrait {
      max-height: none;
      min-height: 100%;
      aspect-ratio: 3 / 4;
    }
  }

  .startup-modal__content {
    padding: 1.5rem 1.5rem 1.75rem;
  }

  .startup-modal__meta {
    margin: 0 0 0.65rem;
    font-size: 0.75rem;
    color: var(--accent-secondary);
  }

  .startup-modal__content h2 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
  }

  .startup-modal__headline {
    margin: 0 0 1rem;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--text);
  }

  .startup-modal__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }

  .startup-modal__tags :global(li) {
    padding: 0.2rem 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(139, 124, 248, 0.1);
    border: 1px solid rgba(139, 124, 248, 0.28);
  }

  .startup-modal__desc {
    margin: 0 0 0.75rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .startup-modal__founder {
    margin: 0 0 1.25rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .startup-modal__quote {
    margin: 0 0 1rem;
    padding: 0.85rem 1rem;
    border-left: 2px solid var(--accent);
    background: var(--bg-elevated);
  }

  .startup-modal__quote p {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text);
  }

  .startup-modal__quote footer {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .startup-modal__quote--investor {
    border-left-color: var(--accent-secondary);
    margin-bottom: 0;
  }
</style>

<script define:vars={{ pageSize }}>
  const grid = document.querySelector("[data-startups-grid]");
  const filtersEl = document.querySelector("[data-startups-filters]");
  const moreWrap = document.querySelector("[data-startups-more]");
  const loadMoreBtn = document.querySelector("[data-load-more]");
  const emptyEl = document.querySelector("[data-startups-empty]");
  const visibleCountEl = document.querySelector("[data-visible-count]");
  const totalCountEl = document.querySelector("[data-total-count]");
  const modal = document.querySelector("[data-startup-modal]");

  if (!grid || !filtersEl || !modal) {
    // page shell missing — nothing to wire
  } else {
    const cards = Array.from(grid.querySelectorAll(".startup-card"));
    let activeFilter = "All";
    let visibleLimit = pageSize;

    function matchesFilter(card, filter) {
      if (filter === "All") return true;
      const verticals = (card.dataset.verticals || "").toLowerCase();
      return verticals.includes(filter.toLowerCase());
    }

    function filteredCards() {
      return cards.filter((c) => matchesFilter(c, activeFilter));
    }

    function applyVisibility() {
      const matched = filteredCards();
      let shown = 0;

      cards.forEach((card) => {
        const match = matchesFilter(card, activeFilter);
        if (!match) {
          card.hidden = true;
          return;
        }
        if (shown < visibleLimit) {
          card.hidden = false;
          shown += 1;
        } else {
          card.hidden = true;
        }
      });

      if (visibleCountEl) visibleCountEl.textContent = String(shown);
      if (totalCountEl) totalCountEl.textContent = String(matched.length);

      if (emptyEl) emptyEl.hidden = matched.length > 0;
      if (moreWrap) moreWrap.hidden = shown >= matched.length || matched.length === 0;
    }

    filtersEl.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-filter]");
      if (!btn) return;
      activeFilter = btn.dataset.filter || "All";
      visibleLimit = pageSize;

      filtersEl.querySelectorAll("[data-filter]").forEach((el) => {
        const on = el === btn;
        el.classList.toggle("startups-filters__btn--active", on);
        el.setAttribute("aria-pressed", on ? "true" : "false");
      });

      applyVisibility();
    });

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", () => {
        visibleLimit += pageSize;
        applyVisibility();
      });
    }

    // —— Modal ——
    const modalImg = modal.querySelector("[data-modal-image]");
    const modalRound = modal.querySelector("[data-modal-round]");
    const modalDate = modal.querySelector("[data-modal-date]");
    const modalCompany = modal.querySelector("[data-modal-company]");
    const modalHeadline = modal.querySelector("[data-modal-headline]");
    const modalTags = modal.querySelector("[data-modal-tags]");
    const modalDesc = modal.querySelector("[data-modal-description]");
    const modalFounder = modal.querySelector("[data-modal-founder]");
    const modalFounderQuote = modal.querySelector("[data-modal-founder-quote]");
    const modalInvestorQuote = modal.querySelector("[data-modal-investor-quote]");

    function formatDate(iso) {
      try {
        return new Date(iso + "T12:00:00").toLocaleDateString("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric",
        });
      } catch {
        return iso;
      }
    }

    function openModal(id) {
      const payloadEl = document.querySelector(
        `[data-startup-payload="${CSS.escape(id)}"]`
      );
      if (!payloadEl) return;

      let data;
      try {
        data = JSON.parse(payloadEl.textContent || "{}");
      } catch {
        return;
      }

      if (modalImg) {
        modalImg.src = data.image || "";
        modalImg.alt = data.founderName
          ? `${data.founderName}, founder of ${data.companyName || ""}`
          : data.companyName || "";
      }
      if (modalRound) modalRound.textContent = data.round || "";
      if (modalDate) {
        modalDate.textContent = formatDate(data.date || "");
        modalDate.setAttribute("datetime", data.date || "");
      }
      if (modalCompany) modalCompany.textContent = data.companyName || "";
      if (modalHeadline) modalHeadline.textContent = data.headline || "";
      if (modalDesc) modalDesc.textContent = data.description || "";
      if (modalFounder) {
        modalFounder.textContent = data.founderTitle
          ? `${data.founderName} · ${data.founderTitle}`
          : data.founderName || "";
      }
      if (modalFounderQuote)
        modalFounderQuote.textContent = data.founderQuote
          ? `“${data.founderQuote}”`
          : "";
      if (modalInvestorQuote)
        modalInvestorQuote.textContent = data.investorQuote
          ? `“${data.investorQuote}”`
          : "";
      if (modalTags) {
        modalTags.innerHTML = "";
        (data.verticals || []).forEach((tag) => {
          const li = document.createElement("li");
          li.textContent = tag;
          modalTags.appendChild(li);
        });
      }

      if (typeof modal.showModal === "function") {
        modal.showModal();
      } else {
        modal.setAttribute("open", "");
      }
    }

    function closeModal() {
      if (typeof modal.close === "function") {
        modal.close();
      } else {
        modal.removeAttribute("open");
      }
    }

    grid.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-startup-open]");
      if (!btn) return;
      openModal(btn.dataset.startupOpen);
    });

    modal.querySelectorAll("[data-startup-close]").forEach((btn) => {
      btn.addEventListener("click", closeModal);
    });

    modal.addEventListener("click", (e) => {
      // click on backdrop (dialog itself, not panel)
      if (e.target === modal) closeModal();
    });

    modal.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeModal();
    });

    applyVisibility();
  }
</script>
