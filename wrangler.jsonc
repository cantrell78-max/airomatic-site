{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "airomatic-site",
  "compatibility_date": "2025-01-01",
  "workers_dev": true,
  "routes": [
    { "pattern": "airomatic.ai", "custom_domain": true },
    { "pattern": "www.airomatic.ai", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist"
  }
}